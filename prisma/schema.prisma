generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  password  String
  role      String   @default("user")
  balance   Float    @default(1000)
  createdAt DateTime @default(now())

  positions    Position[]
  transactions Transaction[]
  comments     Comment[]
  payments     Payment[]
}

model Market {
  id          String    @id @default(cuid())
  title       String
  description String?
  category    String    @default("Geral")
  status      String    @default("open")
  resolution  String?
  emoji       String    @default("📊")
  volume      Float     @default(0)
  endsAt      DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  outcomes  Outcome[]
  positions Position[]
  comments  Comment[]
}

model Outcome {
  id          String @id @default(cuid())
  marketId    String
  label       String
  probability Float  @default(50)
  shares      Float  @default(0)

  market    Market     @relation(fields: [marketId], references: [id])
  positions Position[]
}

model Position {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  outcomeId String
  shares    Float
  avgPrice  Float
  status    String   @default("open")
  pnl       Float    @default(0)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  market  Market  @relation(fields: [marketId], references: [id])
  outcome Outcome @relation(fields: [outcomeId], references: [id])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Float
  detail    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  text      String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  market Market @relation(fields: [marketId], references: [id])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Float
  status      String   @default("pending")
  externalId  String?
  pixCode     String?
  pixQRCode   String?
  pixKey      String?
  pixKeyType  String?
  detail      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
